# ===========================================
# Hermes Show 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填写您的配置
# cp .env.example .env

# ===========================================
# Hermes 路径配置（跨平台）
# ===========================================

# Linux/macOS 默认: ~/.hermes
# Windows 默认: C:\Users\<用户名>\.hermes
# WSL 访问 Windows: 可指定 /mnt/c/Users/<用户名>/.hermes
# Windows 访问 WSL: 可指定 \\wsl$\Ubuntu-20.04\home\<用户>\.hermes

# 自定义 Hermes 配置目录路径（可选）
# NUXT_HERMES_PATH=/home/user/.hermes

# ===========================================
# 网关授权配置
# ===========================================

# 是否允许所有用户访问（默认: false）
# NUXT_GATEWAY_ALLOW_ALL_USERS=false

# 微信是否允许所有用户访问（默认: false）
# NUXT_WEIXIN_ALLOW_ALL_USERS=false

# 微信消息策略: open | pairing（默认: pairing）
# NUXT_WEIXIN_DM_POLICY=pairing

# ===========================================
# 运行环境配置
# ===========================================

# CI 环境（用于测试）
# CI=false

# 工作目录（用于执行定时任务等）
# NUXT_WORK_DIR=/home/user

# ===========================================
# 开发配置
# ===========================================

# 开发服务器端口（默认: 3000）
# NUXT_PORT=3000

# 开发服务器主机（默认: localhost）
# NUXT_HOST=localhost

# ===========================================
# 数据库配置（可选）
# ===========================================

# SQLite 数据库路径（默认: <hermes_path>/state.db）
# DATABASE_URL=file:/path/to/state.db
