generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id              String  @id
  title           String?
  source_platform String?
  started_at      Float?
  ended_at        Float?
  input_tokens    Int?
  output_tokens   Int?

  messages        Message[]

  @@map("sessions")
}

model Message {
  id            Int     @id @default(autoincrement())
  session_id    String
  role          String?
  content       String?
  tool_name     String?
  timestamp     Float
  tool_call_id  String?
  tool_calls    String?
  token_count   Int?
  finish_reason String?
  reasoning     String?

  session       Session? @relation(fields: [session_id], references: [id])

  @@map("messages")
}
